# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
LOG_HEALTHCHECK_REQUESTS=false

# Public URLs
PUBLIC_APP_URL=https://hatchery.auranord.net
PUBLIC_API_URL=https://hatchery.auranord.net
CORS_ORIGIN=https://hatchery.auranord.net

# Database
DATABASE_URL=postgres://erwin_hatchery:change_me@postgres:5432/erwin_hatchery
POSTGRES_DB=erwin_hatchery
POSTGRES_USER=erwin_hatchery
POSTGRES_PASSWORD=change_me

# Sessions / security
SESSION_SECRET=change_me_long_random_string
OVERLAY_SECRET=change_me_long_random_overlay_secret
ADMIN_BOOTSTRAP_ENABLED=true

# Twitch OAuth / EventSub
TWITCH_CLIENT_ID=change_me
TWITCH_CLIENT_SECRET=change_me
TWITCH_BROADCASTER_ID=change_me
TWITCH_EVENTSUB_SECRET=change_me_long_random_string
TWITCH_EVENTSUB_AUTO_SYNC=true

# Incubation tuning
INCUBATION_OFFLINE_MULTIPLIER=1.0
INCUBATION_LIVE_BASE_MULTIPLIER=2.0
INCUBATION_VIEWER_MULTIPLIER_PER_VIEWER=0.01
INCUBATION_MAX_MULTIPLIER=3.0


# Debug tuning
DEBUG_MODE=false
DEBUG_EGG_RESOURCE_MULTIPLIER=1

# Feature flags
FEATURE_BITS_EFFECTS=false
FEATURE_SUB_INCUBATOR=true
FEATURE_CLOUDFLARE_PAGES_FRONTEND=false
