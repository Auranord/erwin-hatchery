{
  "name": "@erwin/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "echo 'No tests for @erwin/api yet'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "pnpm db:migrate:dev",
    "db:seed": "node dist/db/seed.js",
    "db:migrate:dev": "drizzle-kit migrate",
    "db:migrate:runtime": "node dist/db/migrate.js"
  },
  "dependencies": {
    "@erwin/shared": "workspace:*",
    "@fastify/static": "^7.0.4",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "fastify": "^4.29.1",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.18.1",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
